# Supabase Configuration (Vite requires VITE_ prefix for client-side access)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Set on Supabase Edge Functions (Dashboard → Edge Functions → Secrets), not in Vite:
# OWNER_PASSCODE=your_owner_unlock_code

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret (for production/local testing)
